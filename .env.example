# ---- Base de datos MySQL ----
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE
DATABASE_URL="mysql://root:password@localhost:3306/alberca"

# ---- Auth.js / NextAuth ----
# Genera un secreto con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# Permite un acceso local sin Google (solo para desarrollo/pruebas).
# En producción déjalo en "false" y usa Google OAuth.
ALLOW_DEV_LOGIN="false"

# ---- Google OAuth + Google Calendar ----
# Crea credenciales OAuth en https://console.cloud.google.com/apis/credentials
# Redirect URI autorizada: https://TU-DOMINIO/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# ID del calendario donde se crean los eventos ("primary" = calendario principal)
GOOGLE_CALENDAR_ID="primary"
