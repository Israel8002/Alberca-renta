generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (NextAuth) models ----------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
}

enum Role {
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Domain models ----------

// Single-row configuration for the business
model Config {
  id            Int      @id @default(1)
  // Precios por día
  priceMonThu   Float    @default(0)
  priceFri      Float    @default(0)
  priceSat      Float    @default(0)
  priceSun      Float    @default(0)
  priceSeason   Float    @default(0)
  priceHoliday  Float    @default(0)
  // Horarios
  checkInTime   String   @default("10:00")
  checkOutTime  String   @default("18:00")
  // Capacidad y anticipos
  minDeposit    Float    @default(0)
  includedGuests Int     @default(0)
  maxCapacity   Int      @default(60)
  extraGuestCost Float   @default(0)
  // Amenidades
  enableGrill      Boolean @default(true)
  enableFurniture  Boolean @default(true)
  enableBathrooms  Boolean @default(true)
  // Contacto / dirección para WhatsApp
  poolAddress   String   @default("")
  businessName  String   @default("Alberca de Eventos")
  // Observaciones generales
  generalNotes  String?  @db.Text
  updatedAt     DateTime @updatedAt
}

model Client {
  id           String        @id @default(cuid())
  fullName     String
  phone        String
  email        String?
  address      String?
  guests       Int           @default(0)
  notes        String?       @db.Text
  reservations Reservation[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id            String            @id @default(cuid())
  clientId      String
  client        Client            @relation(fields: [clientId], references: [id])
  date          DateTime          // día del evento
  checkIn       String            // "10:00"
  checkOut      String            // "18:00"
  guests        Int               @default(0)
  price         Float             @default(0)
  deposit       Float             @default(0)
  status        ReservationStatus @default(APARTADO)
  notes         String?           @db.Text
  googleEventId String?
  payments      Payment[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([date])
}

enum ReservationStatus {
  DISPONIBLE
  APARTADO
  LIQUIDADO
  CANCELADO
  MANTENIMIENTO
}

model Payment {
  id            String       @id @default(cuid())
  reservationId String
  reservation   Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  amount        Float
  type          PaymentType  @default(ANTICIPO)
  method        String?
  note          String?
  createdAt     DateTime     @default(now())
}

enum PaymentType {
  ANTICIPO
  PARCIAL
  FINAL
}

// Días bloqueados / mantenimiento
model BlockedDate {
  id     String          @id @default(cuid())
  date   DateTime        @unique
  type   BlockedDateType @default(BLOCKED)
  reason String?
}

enum BlockedDateType {
  BLOCKED
  MAINTENANCE
}
